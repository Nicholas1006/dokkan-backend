{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Move new files",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/localMoveFilesToFrontend.py"
      ],
      "problemMatcher": []
    },
    

    {
      "label": "Open Farmbot",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "cd Dokkan_Asset_Downloader && Dokkan_Asset_Downloader_v2.5.2_WIN_x64.exe"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Use new database",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Expand database",
        "Create all jsons"
      ],
      "problemMatcher": []
    },

    {
      "label": "Open Frontend",
      "type": "shell",
      "command": "code",
      "args": [
        "${workspaceFolder}/../frontend"
      ],
      "group":{
        "kind": "none",
        "isDefault": false
      },
      "problemMatcher": [],
      "detail":"Opens the frontend side for the website within vscode",
      "presentation": {
        "reveal": "silent",  
        "close": true        
      }
    },
    {
      "label": "Open Json",
      "type": "shell",
      "command": "code",
      "args": [
        "${workspaceFolder}/../frontend/dbManagement/jsons/${input:jsonFile}.json"
      ],
      "problemMatcher": [],
      "presentation": {
        "close":true,
        "reveal": "silent"
      }
    },
    {
      "label": "Open Json Eza",
      "type": "shell",
      "command": "code",
      "args": [
        "${workspaceFolder}/../frontend/dbManagement/jsonsEZA/${input:jsonFile}.json"
      ],
      "problemMatcher": [],
      "presentation": {
        "close":true,
        "reveal": "silent"
      }
    },
    {
      "label": "Open Json Super Eza",
      "type": "shell",
      "command": "code",
      "args": [
        "${workspaceFolder}/../frontend/dbManagement/jsonsSEZA/${input:jsonFile}.json"
      ],
      "problemMatcher": [],
      "presentation": {
        "close":true,
        "reveal": "silent"
      }
    },
    {
      "label": "Expand database",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "python",
        "Database_expander.py"
      ],
      "problemMatcher": [],
      "presentation": {
        "close": true,
        "reveal": "always"
      },
      "options": {
        "statusbar": {
          "hide": true
        }
      }
    },

    {
      "label": "Create jsons",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "python",
        "dokkan_Json_creator.py"
      ],
      "problemMatcher": [],
      "presentation": {
        "close":true,
        "reveal": "always"
      },
      "options": {
        "statusbar": {
          "hide" : true
        }
      }
    },


    {
      "label": "Create unique Jsons",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "python",
        "uniqueJsonCreator.py"
      ],
      "problemMatcher": [],
      "presentation": {
        "close":true,
        "reveal": "always"
      },
      "options": {
        "statusbar": {
          "hide" : true
        }
      }
    },


    {
      "label": "Create all jsons",
      "dependsOrder": "parallel",
      "dependsOn": [
        "Create jsons",
        "Create unique Jsons"
      ],
      "problemMatcher": [],
      "options": {
        "statusbar": {
          "hide" : true
        }
      }
    },

  ],
  "inputs": [
    {
      "id": "jsonFile",
      "type": "promptString",
      "description": "Enter the JSON filename (e.g., 1020091)"
    }
  ]
}
