{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Open Farmbot",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "cd Smile Farmbot && python main.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Use new database",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "python 'Use_after_DDL.py'"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "detail": "Uses the new database within glb.db and jp.db to create updated assets and json files"
    },

    {
      "label": "Open Frontend",
      "type": "shell",
      "command": "code",
      "args": [
        "${workspaceFolder}/../frontend"
      ],
      "group":{
        "kind": "none",
        "isDefault": false
      },
      "problemMatcher": [],
      "detail":"Opens the frontend side for the website within vscode"
    },
    
  ]
}
